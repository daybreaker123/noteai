# Database (Prisma) — PostgreSQL in production (Vercel Postgres, Neon, Supabase, etc.)
# Local: use a Postgres URL or Docker. Prisma migrations: `npx prisma migrate deploy` on deploy.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth (required for sign-in and OAuth)
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-long-random-string"
# Canonical site URL — REQUIRED in production (Vercel: https://your-app.vercel.app). No trailing slash.
NEXTAUTH_URL="http://localhost:3000"
# Public URL for client-side links (match NEXTAUTH_URL in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# On some hosts (e.g. behind proxies) set to true if OAuth redirects misbehave
# AUTH_TRUST_HOST="true"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URIs (add each environment you use):
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_PRODUCTION_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase (categories, notes, plans, embeddings)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# OpenAI (embeddings for semantic search)
OPENAI_API_KEY=""

# Anthropic Claude (AI summarization, chat, etc.)
ANTHROPIC_API_KEY=""

# Stripe (Pro subscription checkout + webhooks)
STRIPE_SECRET_KEY=""
# Monthly Pro (e.g. $14/mo) — recurring price ID from Stripe Dashboard
STRIPE_PRICE_ID=""
# Annual Pro (e.g. $134/yr) — create a second product/price in Stripe, then paste its price ID
STRIPE_ANNUAL_PRICE_ID=""
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=""

# Resend (transactional email — welcome, Pro upgrade, password reset). Get API key at https://resend.com
# Reset links use NEXTAUTH_URL (or NEXT_PUBLIC_APP_URL) as the site origin — set correctly in production.
# Verify sending domain (e.g. studara.org) in Resend before using noreply@studara.org
RESEND_API_KEY=""
# Optional override — default: Studara <noreply@studara.org>
# RESEND_FROM="Studara <noreply@studara.org>"
